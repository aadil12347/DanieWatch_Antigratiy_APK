{
  "mailer_templates": {
    "confirmation": {
      "subject": "Confirm Your DanieWatch Account",
      "content": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"utf-8\">\n    <style>\n        body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; background-color: #141413; color: #E4E4E7; margin: 0; padding: 0; }\n        .container { max-width: 600px; margin: 40px auto; background-color: #1A1A19; border-radius: 24px; padding: 40px; border: 1px solid #3F3F46; }\n        .header { text-align: center; margin-bottom: 32px; }\n        .logo { color: #B81D24; font-size: 32px; font-weight: bold; letter-spacing: 2px; text-decoration: none; }\n        .content { line-height: 1.6; font-size: 16px; margin-bottom: 32px; }\n        .button-container { text-align: center; }\n        .button { background-color: #B81D24; color: white; padding: 16px 32px; border-radius: 12px; text-decoration: none; font-weight: bold; display: inline-block; }\n        .footer { text-align: center; font-size: 12px; color: #71717A; margin-top: 40px; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <a href=\"{{ .SiteURL }}\" class=\"logo\">DANIEWATCH</a>\n        </div>\n        <div class=\"content\">\n            <h2>Welcome to the Cinema, {{ .Data.username }}!</h2>\n            <p>You're one step away from starting your premium streaming experience. Please confirm your email address by clicking the button below.</p>\n        </div>\n        <div class=\"button-container\">\n            <a href=\"{{ .ConfirmationURL }}\" class=\"button\">Confirm My Account</a>\n        </div>\n        <p class=\"content\">If the button above doesn't work, copy and paste this link into your browser:</p>\n        <p style=\"word-break: break-all; color: #6A9BCC;\">{{ .ConfirmationURL }}</p>\n        <div class=\"footer\">\n            &copy; 2026 DanieWatch. All rights reserved.<br>\n            Sit back, relax, and enjoy the show.\n        </div>\n    </div>\n</body>\n</html>"
    },
    "recovery": {
      "subject": "Reset Your DanieWatch Password",
      "content": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"utf-8\">\n    <style>\n        body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; background-color: #141413; color: #E4E4E7; margin: 0; padding: 0; }\n        .container { max-width: 600px; margin: 40px auto; background-color: #1A1A19; border-radius: 24px; padding: 40px; border: 1px solid #3F3F46; }\n        .header { text-align: center; margin-bottom: 32px; }\n        .logo { color: #B81D24; font-size: 32px; font-weight: bold; letter-spacing: 2px; text-decoration: none; }\n        .content { line-height: 1.6; font-size: 16px; margin-bottom: 32px; }\n        .button-container { text-align: center; }\n        .button { background-color: #B81D24; color: white; padding: 16px 32px; border-radius: 12px; text-decoration: none; font-weight: bold; display: inline-block; }\n        .footer { text-align: center; font-size: 12px; color: #71717A; margin-top: 40px; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <a href=\"{{ .SiteURL }}\" class=\"logo\">DANIEWATCH</a>\n        </div>\n        <div class=\"content\">\n            <h2>Reset Your Password</h2>\n            <p>We received a request to change your password. Your security is our top priority. Click the button below to update your login credentials.</p>\n        </div>\n        <div class=\"button-container\">\n            <a href=\"{{ .ConfirmationURL }}\" class=\"button\">Set New Password</a>\n        </div>\n        <p class=\"content\">If you did not request a password reset, you can safely ignore this email.</p>\n        <p style=\"word-break: break-all; color: #6A9BCC;\">{{ .ConfirmationURL }}</p>\n        <div class=\"footer\">\n            &copy; 2026 DanieWatch. All rights reserved.<br>\n            Secure access, cinematic experience.\n        </div>\n    </div>\n</body>\n</html>"
    },
    "email_change": {
      "subject": "Confirm Your New Email for DanieWatch",
      "content": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"utf-8\">\n    <style>\n        body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; background-color: #141413; color: #E4E4E7; margin: 0; padding: 0; }\n        .container { max-width: 600px; margin: 40px auto; background-color: #1A1A19; border-radius: 24px; padding: 40px; border: 1px solid #3F3F46; }\n        .header { text-align: center; margin-bottom: 32px; }\n        .logo { color: #B81D24; font-size: 32px; font-weight: bold; letter-spacing: 2px; text-decoration: none; }\n        .content { line-height: 1.6; font-size: 16px; margin-bottom: 32px; }\n        .button-container { text-align: center; }\n        .button { background-color: #B81D24; color: white; padding: 16px 32px; border-radius: 12px; text-decoration: none; font-weight: bold; display: inline-block; }\n        .footer { text-align: center; font-size: 12px; color: #71717A; margin-top: 40px; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <a href=\"{{ .SiteURL }}\" class=\"logo\">DANIEWATCH</a>\n        </div>\n        <div class=\"content\">\n            <h2>Confirm Your New Email</h2>\n            <p>You requested a change to your DanieWatch login email. To complete the process and secure your account, please click the button below to confirm the new address.</p>\n        </div>\n        <div class=\"button-container\">\n            <a href=\"{{ .ConfirmationURL }}\" class=\"button\">Confirm New Email</a>\n        </div>\n        <p class=\"content\">If you did not request this change, please ignore this message.</p>\n        <p style=\"word-break: break-all; color: #6A9BCC;\">{{ .ConfirmationURL }}</p>\n        <div class=\"footer\">\n            &copy; 2026 DanieWatch. All rights reserved.<br>\n            Cinema at your fingertips.\n        </div>\n    </div>\n</body>\n</html>"
    }
  }
}
